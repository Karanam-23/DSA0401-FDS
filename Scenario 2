import numpy as np

# Rows = Products
# Columns = Sales prices during the month
sales_data = np.array([
    [100, 120, 110],
    [200, 210, 220],
    [150, 140, 160]
])

# Calculate the average price of all products sold
average_price = np.mean(sales_data)

print("Average Price of All Products Sold:", average_price)
