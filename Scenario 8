import pandas as pd
import numpy as np

# Create a sample sales DataFrame for the past month
sales_data_month = pd.DataFrame({
    'product_name': np.random.choice(['Laptop', 'Mouse', 'Keyboard', 'Monitor', 'Webcam', 'Headphones', 'Speaker', 'Microphone'], size=50),
    'quantity_sold': np.random.randint(1, 10, size=50)
})

print("Sample Sales Data (first 10 rows):\n", sales_data_month.head(10))
print("\n" + "-"*30 + "\n")

# Calculate total quantity sold for each product
total_sales_per_product = sales_data_month.groupby('product_name')['quantity_sold'].sum()

# Sort in descending order and get the top 5
top_5_products = total_sales_per_product.sort_values(ascending=False).head(5)

print("Top 5 products sold the most in the past month:\n", top_5_products)
