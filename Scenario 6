import numpy as np

# Scenario 6: Calculate total cost of a customer's purchase with discounts and taxes

# Item prices and quantities
item_prices = np.array([2.50, 1.75, 5.00, 3.25]) # prices of individual items
quantities = np.array([2, 3, 1, 2]) # quantities of each item

# Discount and tax rates (as percentages)
discount_rate_percent = 10 # 10% discount
tax_rate_percent = 8 # 8% tax

print("Item Prices:", item_prices)
print("Quantities:", quantities)
print(f"Discount Rate: {discount_rate_percent}%")
print(f"Tax Rate: {tax_rate_percent}%")

# 1. Calculate the subtotal before discount and tax
subtotal = np.sum(item_prices * quantities)
print(f"\nSubtotal: ${subtotal:.2f}")

# 2. Apply discount
discount_amount = subtotal * (discount_rate_percent / 100)
price_after_discount = subtotal - discount_amount
print(f"Discount Amount ({discount_rate_percent}%): ${discount_amount:.2f}")
print(f"Price After Discount: ${price_after_discount:.2f}")

# 3. Apply tax
tax_amount = price_after_discount * (tax_rate_percent / 100)
total_cost = price_after_discount + tax_amount
print(f"Tax Amount ({tax_rate_percent}%): ${tax_amount:.2f}")

# 4. Total cost for the customer
print(f"Total Cost for the customer: ${total_cost:.2f}")
